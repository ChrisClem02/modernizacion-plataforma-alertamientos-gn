# Variables para ejecutar el backend fuera de Docker durante desarrollo local.
# Cuando el backend corre dentro de Docker, Compose sobrescribe estos valores.

NODE_ENV=development
BACKEND_PORT=3001
DB_HOST=localhost
DB_PORT=5450
DB_NAME=mpna_gn
DB_USER=postgres
DB_PASSWORD=cambia_esta_contrasena
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=cambia_este_secreto
JWT_EXPIRES_IN=8h
